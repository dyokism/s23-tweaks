#!/sbin/sh
umask 022
ui_print() { echo "$1"; }
OUTFD=$2
ZIPFILE=$3
mount /data 2>/dev/null

if [ "$KSU" = "true" ] || [ "$APATCH" = "true" ]; then
  if [ -f /data/adb/ksu/module.prop ]; then
    MAGISKTMP=
  fi
else
  if [ -f /data/adb/magisk/util_functions.sh ]; then
    . /data/adb/magisk/util_functions.sh
    [ "$MAGISK_VER_CODE" -lt 20400 ] && {
      ui_print "Please install Magisk v20.4+!"
      # Exit is safe here because this script is executed (not sourced) by the installer.
      exit 1
    }
    install_module
    # Exit is safe here because this script is executed (not sourced) by the installer.
    exit 0
  fi
fi

ui_print "ERROR: No supported root manager detected."
ui_print "Supported: Magisk v20.4+, KernelSU, APatch."
# Exit is safe here because this script is executed (not sourced) by the installer.
exit 1
